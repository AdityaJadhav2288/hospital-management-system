generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Admin {
  id        String   @id @default(cuid())
  name      String   @default("Hospital Administrator")
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Doctor {
  id            String         @id @default(cuid())
  name          String
  specialization String
  email         String         @unique
  password      String
  experience    Int
  phone         String
  department    String
  profileImage  String
  bio           String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  prescriptions Prescription[]
  vitalsRecorded Vitals[]

  @@index([specialization])
  @@index([department])
  @@map("doctors")
}

model Patient {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  phone         String
  address       String         @default("Not provided")
  dateOfBirth   DateTime?
  gender        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  prescriptions Prescription[]
  vitals        Vitals[]

  @@map("patients")
}

model Appointment {
  id            String            @id @default(cuid())
  patientId     String
  doctorId      String
  date          DateTime
  status        AppointmentStatus @default(PENDING)
  reason        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([doctorId])
  @@index([patientId])
  @@index([date])
  @@map("appointments")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String?
  createdAt   DateTime @default(now())

  @@map("departments")
}

model HealthPackage {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  features    String[]
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("health_packages")
}

model BloodStock {
  id          String   @id @default(cuid())
  bloodGroup  String   @unique
  units       Int
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("blood_stocks")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("contact_messages")
}

model Prescription {
  id            String       @id @default(cuid())
  doctorId      String
  patientId     String
  appointmentId String?
  medication    String
  dosage        String
  instructions  String
  createdAt     DateTime     @default(now())
  doctor        Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([patientId])
  @@map("prescriptions")
}

model Vitals {
  id                 String   @id @default(cuid())
  patientId          String
  recordedByDoctorId String?
  heightCm           Float?
  weightKg           Float?
  bloodPressure      String?
  pulseRate          Int?
  notes              String?
  recordedAt         DateTime @default(now())
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedByDoctor   Doctor?  @relation(fields: [recordedByDoctorId], references: [id], onDelete: SetNull)

  @@index([patientId, recordedAt])
  @@map("vitals")
}
